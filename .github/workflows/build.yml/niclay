name: Build Windows EXE

on:
  workflow_dispatch:   # Actions sekmesinden manuel "Run workflow" ile tetikler
  push:
    branches: [ main ]

jobs:
  build:
    runs-on: windows-latest   # GitHub'ın kendi bulut Windows makinesi - senin diskin kullanılmaz

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup .NET 8 SDK
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'

      - name: Restore
        run: dotnet restore TravBotSharp.sln

      - name: Publish self-contained win-x64 exe
        run: >
          dotnet publish WPFUI/WPFUI.csproj
          -c Release
          -r win-x64
          --self-contained true
          -p:PublishSingleFile=true
          -o publish

      - name: Upload build result
        uses: actions/upload-artifact@v4
        with:
          name: TravianBotSharp-win-x64
          path: publish/
